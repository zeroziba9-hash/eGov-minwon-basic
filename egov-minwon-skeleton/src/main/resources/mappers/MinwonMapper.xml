<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="egov.minwon.service.impl.MinwonMapper">

    <resultMap id="minwonResultMap" type="egov.minwon.service.MinwonVO">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="selectMinwonList" resultMap="minwonResultMap">
        SELECT id, title, content, status, created_at
        FROM minwon
        ORDER BY id DESC
    </select>

    <insert id="insertMinwon" parameterType="egov.minwon.service.MinwonVO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO minwon (title, content, status, created_at)
        VALUES (#{title}, #{content}, #{status}, CURRENT_TIMESTAMP)
    </insert>

    <update id="updateMinwonStatus">
        UPDATE minwon
        SET status = #{status}
        WHERE id = #{id}
    </update>

</mapper>
